# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Firebase
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
FIREBASE_PROJECT_ID=classroom-management-app-be807

# Instructor seed
INSTRUCTOR_PHONE=1234567890
INSTRUCTOR_NAME=Demo Instructor
INSTRUCTOR_EMAIL=instructor@example.com

# Twilio Verify — https://console.twilio.com → Develop → Verify → Services
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Dev: bỏ qua Twilio Verify, hiện mã OTP trên web
# SMS_DEV_MODE=true

# JWT (student email/password login)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# SMTP — Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
